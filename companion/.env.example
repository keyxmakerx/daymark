# Daymark Companion — example environment.
# Copy to `.env` (gitignored) and adjust. Compose reads variables referenced as
# ${VAR} automatically; the scaffold sets sane defaults inline in docker-compose.yml,
# so this file mainly documents the surface. Names match docs/COMPANION_DEPLOYMENT.md.

# --- Networking / serving ---
DAYMARK_BIND_ADDR=0.0.0.0
DAYMARK_PORT=8080
DAYMARK_BASE_PATH=/            # set to e.g. /daymark to serve under a sub-path
DAYMARK_DATA_DIR=/data
DAYMARK_LOG_LEVEL=info

# --- Reverse proxy (consumed in the sync milestone; documented now) ---
# Default is TRUST NO forwarded headers. Only when a proxy fronts the service, pin its
# exact source IP/CIDR here so X-Forwarded-* is honoured ONLY from that proxy. Never use
# a broad range like 172.16.0.0/12 — any co-resident container could then spoof headers.
# DAYMARK_TRUSTED_PROXIES=10.89.0.2/32
# DAYMARK_FORWARDED_HEADERS=x-forwarded

# --- Outbound SMTP (the ONE deliberate egress exception; OFF by default) ---
# Enabled ONLY when DAYMARK_SMTP_HOST is set. Egresses to this one host:port, requires
# TLS, and its emails carry ONLY therapist invite/notification LINKS — never any record
# or plaintext content. Enabling it requires a narrow egress path to this mail host (see
# docs/COMPANION_DEPLOYMENT.md §8). Password should come from a *_FILE secret.
# DAYMARK_SMTP_HOST=mail.example.org
# DAYMARK_SMTP_PORT=587                 # 587 STARTTLS, or 465 with implicit TLS
# DAYMARK_SMTP_TLS=starttls             # starttls | implicit (never 'none' — refused)
# DAYMARK_SMTP_FROM=companion@example.org
# DAYMARK_SMTP_USER=companion           # optional; omit for unauthenticated submission
# DAYMARK_SMTP_PASS_FILE=/run/secrets/companion_smtp_pass

# --- Reserved for later milestones (sync / auth / shares) — not yet consumed ---
# DAYMARK_AUTH_TOKEN_FILE=/run/secrets/companion_auth_token
# DAYMARK_MAX_BLOB_BYTES=26214400
# DAYMARK_MAX_VERSIONS=200
# DAYMARK_RATE_LIMIT_RPS=5
# DAYMARK_WEBAUTHN_RP_ID=daymark.example.com
# DAYMARK_WEBAUTHN_ORIGINS=https://daymark.example.com
